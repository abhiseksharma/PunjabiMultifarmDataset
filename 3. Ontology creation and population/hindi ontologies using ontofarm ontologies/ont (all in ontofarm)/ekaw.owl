    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="वेबसाइट"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="बहु_लेखक_वॉल्यूम"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:about="#नियमित_शोध_पत्र">
    <owl:disjointWith rdf:resource="#औद्योगिक_शोध_पत्र"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#पोस्टर_पत्र"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#डेमो_शोध_पत्र"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#शोध_पत्र"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#आमंत्रित_वार्ता">    
    <owl:disjointWith>
      <owl:Class rdf:about="#कार्यशाला"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#सामाजिक_कार्यक्रम"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#ट्यूटोरियल"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#योगदान_दिया_वार्ता"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:ID="व्यक्तिगत_प्रस्तुति"/>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="#संकरा_रास्ता"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#सम्मेलन"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#सत्र"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:about="#सामाजिक_कार्यक्रम">
    <owl:disjointWith>
      <owl:Class rdf:about="#योगदान_दिया_वार्ता"/>
    </owl:disjointWith>
    <rdfs:subClassOf rdf:resource="#कार्यक्रम"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#सम्मेलन"/>
    </owl:disjointWith>
    <owl:disjointWith rdf:resource="#आमंत्रित_वार्ता"/>
    <owl:disjointWith rdf:resource="#संकरा_रास्ता"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#कार्यशाला"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#ट्यूटोरियल"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="ओसी_कुर्सी">
    <rdfs:subClassOf rdf:resource="#ओसी_सदस्य"/>
  </owl:Class>
  <owl:Class rdf:ID="सम्मेलन_भोज">
    <rdfs:subClassOf rdf:resource="#सामाजिक_कार्यक्रम"/>
  </owl:Class>
  <owl:Class rdf:about="#बहु_लेखक_वॉल्यूम">
    <owl:disjointWith rdf:resource="#समीक्षा"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#कार्यक्रम_विवरणिका"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#शोध_पत्र"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#वेबसाइट"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#दस्तावेज़"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:about="#उड़ाका"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="कार्यशाला_अध्यक्ष">
    <rdfs:subClassOf rdf:resource="#सम्मेलन_प्रतिभागी"/>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#कार्यक्रम_समिति_सदस्य"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:about="#कार्यक्रम_समिति_अध्यक्ष"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:about="#सबमिट_किया_गया_पेपर">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#शोध_पत्र"/>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="#कैमरा_तैयार_शोध_पत्र"/>
  </owl:Class>
  <owl:Class rdf:about="#वेबसाइट">
    <owl:disjointWith>
      <owl:Class rdf:about="#कार्यक्रम_विवरणिका"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#दस्तावेज़"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:about="#कार्यवाही"/>
    </owl:disjointWith>
    <owl:disjointWith rdf:resource="#समीक्षा"/>
    <owl:disjointWith rdf:resource="#बहु_लेखक_वॉल्यूम"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#उड़ाका"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#शोध_पत्र"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="सम्मेलन_की_कार्यवाही">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#कार्यवाही"/>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="वॉल्यूमकंटेन्सपेपर"/>
        </owl:onProperty>
        <owl:allValuesFrom>
          <owl:Class>
            <owl:unionOf rdf:parseType="Collection">
              <owl:Class rdf:about="#सम्मेलन_शोध_पत्र"/>
              <owl:Class rdf:about="#आमंत्रित_टॉक_सार"/>
            </owl:unionOf>
          </owl:Class>
        </owl:allValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#कार्यशाला">
    <owl:disjointWith>
      <owl:Class rdf:about="#सम्मेलन"/>
    </owl:disjointWith>    
    <owl:disjointWith>
      <owl:Class rdf:about="#सत्र"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#ट्यूटोरियल"/>
    </owl:disjointWith>
    <owl:disjointWith rdf:resource="#संकरा_रास्ता"/>
    <owl:disjointWith rdf:resource="#सामाजिक_कार्यक्रम"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#व्यक्तिगत_प्रस्तुति"/>
