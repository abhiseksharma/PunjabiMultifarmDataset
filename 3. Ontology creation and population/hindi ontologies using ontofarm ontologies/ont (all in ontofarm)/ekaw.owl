    </owl:disjointWith>    
    <owl:disjointWith>
      <owl:Class rdf:about="#सामाजिक_कार्यक्रम"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="योगदान_दिया_वार्ता"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="सम्मेलन"/>
    </owl:disjointWith>
    <rdfs:subClassOf rdf:resource="#वैज्ञानिक_कार्यक्रम"/>
  </owl:Class>
  <owl:Class rdf:ID="डेमो_अध्यक्ष">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#सम्मेलन_प्रतिभागी"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#सम्मेलन_प्रतिभागी">
    <rdfs:subClassOf rdf:resource="#व्यक्ति"/>
  </owl:Class>
  <owl:Class rdf:ID="ट्यूटोरियल_कुर्सी">
