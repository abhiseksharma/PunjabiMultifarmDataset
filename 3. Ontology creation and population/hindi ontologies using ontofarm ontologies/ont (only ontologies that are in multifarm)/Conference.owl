<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns="http://conference#"
  xml:base="http://conference">
  <owl:Ontology rdf:about=""/>
  <owl:Class rdf:ID="सम्मेलन_प्रतिभागी">
    <owl:equivalentClass>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:ID="सक्रिय_सम्मेलन_प्रतिभागी"/>
          <owl:Class rdf:ID="निष्क्रिय_सम्मेलन_प्रतिभागी"/>
        </owl:unionOf>
      </owl:Class>
    </owl:equivalentClass>
    <rdfs:subClassOf>
      <owl:Class rdf:ID="व्यक्ति"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="समीक्षा_विशेषज्ञ">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="सबमिट_किया_गया_योगदान_है"/>
        </owl:onProperty>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="सबमिट_किया_गया_योगदान"/>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="समीक्षाक"/>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="समीक्षकों_के_अंतर्गत_आता_है"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="नियमित_लेखक">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="सम्मेलन_योगदानकर्ता"/>
    </rdfs:subClassOf>
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class>
            <owl:unionOf rdf:parseType="Collection">
              <owl:Class rdf:ID="योगदान_पहला_लेखक"/>
              <owl:Class rdf:ID="योगदान_सह_लेखक"/>
            </owl:unionOf>
          </owl:Class>
          <owl:Restriction>
            <owl:someValuesFrom>
              <owl:Class rdf:ID="सम्मेलन_योगदान"/>
            </owl:someValuesFrom>
            <owl:onProperty>
              <owl:ObjectProperty rdf:ID="योगदान"/>
            </owl:onProperty>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="सह_अध्यक्ष">
    <owl:equivalentClass>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="समिति"/>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="की_एक_समिति_के_सह-अध्यक्ष_थे"/>
        </owl:onProperty>
      </owl:Restriction>
    </owl:equivalentClass>
    <rdfs:subClassOf>
      <owl:Class rdf:ID="समिति_सदस्य"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="सार">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="विस्तारित_सार"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="महत्वपूर्ण_तिथियाँ"/>
  <owl:Class rdf:about="#सक्रिय_सम्मेलन_प्रतिभागी">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#सम्मेलन_योगदानकर्ता"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:about="#निष्क्रिय_सम्मेलन_प्रतिभागी"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:ID="आमंत्रित_अध्यक्ष"/>
          <owl:Class rdf:about="#नियमित_लेखक"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="#सम्मेलन_प्रतिभागी"/>
  </owl:Class>
  <owl:Class rdf:ID="सम्मेलन_की_कार्यवाही"/>
  <owl:Class rdf:ID="जानकारी_प्रतिभागियों_के_लिए">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="सम्मेलन_दस्तावेज़"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="संगठन"/>
  <owl:Class rdf:about="#सबमिट_किया_गया_योगदान">
    <rdfs:subClassOf>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:ID="नियमित_योगदान"/>
          <owl:Class rdf:ID="पोस्टर"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Class rdf:ID="लिखित_योगदान"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="सम्मेलन_आवेदक">
    <rdfs:subClassOf rdf:resource="#व्यक्ति"/>
  </owl:Class>
  <owl:Class rdf:ID="कैमरा_तैयार_योगदान">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="स्वीकृत_योगदान"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="कार्यक्रम_समिति">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#समिति"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:ID="आयोजन_समिति"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="संचालन_समिति"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="सम्मेलन_की_मात्रा">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="सम्मेलन"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#योगदान_पहला_लेखक">
    <rdfs:subClassOf rdf:resource="#नियमित_लेखक"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#योगदान_सह_लेखक"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:about="#समिति">
    <owl:equivalentClass>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#आयोजन_समिति"/>
          <owl:Class rdf:about="#कार्यक्रम_समिति"/>
          <owl:Class rdf:about="#संचालन_समिति"/>
        </owl:unionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="शोध_पत्रों_के_लिए_कॉल">
    <rdfs:subClassOf rdf:resource="#सम्मेलन_दस्तावेज़"/>
  </owl:Class>
  <owl:Class rdf:ID="सम्मेलन_घोषणा">
    <rdfs:subClassOf rdf:resource="#सम्मेलन_दस्तावेज़"/>
  </owl:Class>
  <owl:Class rdf:about="#समिति_सदस्य">
    <owl:equivalentClass>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#समिति"/>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="का_सदस्य_था"/>
        </owl:onProperty>
      </owl:Restriction>
    </owl:equivalentClass>
    <rdfs:subClassOf rdf:resource="#व्यक्ति"/>
  </owl:Class>
  <owl:Class rdf:about="#नियमित_योगदान">
    <owl:equivalentClass>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#विस्तारित_सार"/>
          <owl:Class rdf:ID="शोध_पत्र"/>
        </owl:unionOf>
      </owl:Class>
    </owl:equivalentClass>
    <owl:disjointWith>
      <owl:Class rdf:ID="आमंत्रित_बात"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#लिखित_योगदान"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:about="#पोस्टर"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="सम्मेलन_भाग"/>
  <owl:Class rdf:about="#सम्मेलन_योगदान">
    <owl:equivalentClass>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#लिखित_योगदान"/>
          <owl:Class rdf:ID="प्रस्तुति"/>
        </owl:unionOf>
      </owl:Class>
    </owl:equivalentClass>
    <rdfs:subClassOf rdf:resource="#सम्मेलन_दस्तावेज़"/>
    <owl:equivalentClass>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#नियमित_योगदान"/>
          <owl:Class rdf:about="#पोस्टर"/>
          <owl:Class rdf:about="#आमंत्रित_बात"/>
        </owl:unionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="अध्यक्ष">
    <owl:equivalentClass>
      <owl:Restriction>
        <owl:onProperty>
          <owl:InverseFunctionalProperty rdf:ID="की_एक_समिति_के_अध्यक्ष_थे"/>
        </owl:onProperty>
        <owl:someValuesFrom rdf:resource="#समिति"/>
      </owl:Restriction>
    </owl:equivalentClass>
    <rdfs:subClassOf rdf:resource="#समिति_सदस्य"/>
  </owl:Class>
  <owl:Class rdf:about="#योगदान_सह_लेखक">
    <rdfs:subClassOf rdf:resource="#नियमित_लेखक"/>
    <owl:disjointWith rdf:resource="#योगदान_पहला_लेखक"/>
  </owl:Class>
  <owl:Class rdf:ID="संकरा_रास्ता">
    <rdfs:subClassOf rdf:resource="#सम्मेलन_भाग"/>
    <owl:disjointWith>
      <owl:Class rdf:ID="कार्यशाला"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="ट्यूटोरियल"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:about="#स्वीकृत_योगदान">
    <owl:disjointWith>
      <owl:Class rdf:ID="अस्वीकृत_योगदान"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:ID="समीक्षित_योगदान"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="समीक्षा">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:allValuesFrom>
          <owl:Class rdf:about="#समीक्षाक"/>
        </owl:allValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="लेखक_हैं"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="#सम्मेलन_दस्तावेज़"/>
  </owl:Class>
  <owl:Class rdf:about="#लिखित_योगदान">
    <rdfs:subClassOf>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#पोस्टर"/>
          <owl:Class rdf:about="#नियमित_योगदान"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="#सम्मेलन_योगदान"/>
  </owl:Class>
  <owl:Class rdf:ID="विषय"/>
  <owl:Class rdf:ID="देर_से_भुगतान_करने_वाला_आवेदक">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="भुगतान_आवेदक"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:ID="अर्ली_पेड_आवेदक"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:about="#पोस्टर">
    <owl:disjointWith>
      <owl:Class rdf:about="#आमंत्रित_बात"/>
