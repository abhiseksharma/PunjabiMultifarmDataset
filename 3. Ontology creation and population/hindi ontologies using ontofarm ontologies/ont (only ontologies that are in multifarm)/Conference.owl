    <rdfs:subClassOf rdf:resource="#सम्मेलन_योगदान"/>
    <owl:disjointWith rdf:resource="#नियमित_योगदान"/>
  </owl:Class>
  <owl:Class rdf:about="#निष्क्रिय_सम्मेलन_प्रतिभागी">
    <rdfs:subClassOf rdf:resource="#सम्मेलन_प्रतिभागी"/>
    <owl:disjointWith rdf:resource="#सक्रिय_सम्मेलन_प्रतिभागी"/>
  </owl:Class>
  <owl:Class rdf:about="#सम्मेलन_योगदानकर्ता">
    <rdfs:subClassOf rdf:resource="#व्यक्ति"/>
  </owl:Class>
  <owl:Class rdf:about="#कार्यशाला">
    <rdfs:subClassOf rdf:resource="#सम्मेलन_भाग"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#ट्यूटोरियल"/>
    </owl:disjointWith>
    <owl:disjointWith rdf:resource="#संकरा_रास्ता"/>
  </owl:Class>
  <owl:Class rdf:ID="व्यवस्था_करने_वाला">
    <rdfs:subClassOf>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#संगठन"/>
          <owl:Class rdf:about="#समिति_सदस्य"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>
  <owl:Class rdf:ID="भागीदारी_के_लिए_कॉल">
    <rdfs:subClassOf rdf:resource="#सम्मेलन_दस्तावेज़"/>
  </owl:Class>
  <owl:Class rdf:ID="प्रकाशक"/>
  <owl:Class rdf:about="#संचालन_समिति">
    <owl:disjointWith rdf:resource="#कार्यक्रम_समिति"/>
    <rdfs:subClassOf rdf:resource="#समिति"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#आयोजन_समिति"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:about="#आयोजन_समिति">
    <rdfs:subClassOf rdf:resource="#समिति"/>
    <owl:disjointWith rdf:resource="#कार्यक्रम_समिति"/>
    <owl:disjointWith rdf:resource="#संचालन_समिति"/>
  </owl:Class>
  <owl:Class rdf:about="#समीक्षाक">
    <rdfs:subClassOf rdf:resource="#व्यक्ति"/>
  </owl:Class>
  <owl:Class rdf:about="#भुगतान_आवेदक">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="पंजीकृत_आवेदक"/>
    </rdfs:subClassOf>
    <owl:equivalentClass>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#अर्ली_पेड_आवेदक"/>
          <owl:Class rdf:about="#देर_से_भुगतान_करने_वाला_आवेदक"/>
        </owl:unionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="ट्रैक-कार्यशाला_कुर्सी">
    <owl:equivalentClass>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class>
            <owl:unionOf rdf:parseType="Collection">
              <owl:Class rdf:about="#संकरा_रास्ता"/>
              <owl:Class rdf:about="#कार्यशाला"/>
            </owl:unionOf>
          </owl:Class>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="की_एक_ट्रैक-कार्यशाला_की_कुर्सी_थी"/>
        </owl:onProperty>
      </owl:Restriction>
    </owl:equivalentClass>
    <rdfs:subClassOf rdf:resource="#व्यक्ति"/>
  </owl:Class>
  <owl:Class rdf:about="#प्रस्तुति">
    <rdfs:subClassOf rdf:resource="#सम्मेलन_योगदान"/>
  </owl:Class>
  <owl:Class rdf:about="#अस्वीकृत_योगदान">
    <owl:disjointWith rdf:resource="#स्वीकृत_योगदान"/>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#समीक्षित_योगदान"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#आमंत्रित_बात">
    <owl:disjointWith rdf:resource="#पोस्टर"/>
    <rdfs:subClassOf rdf:resource="#प्रस्तुति"/>
    <owl:disjointWith rdf:resource="#नियमित_योगदान"/>
  </owl:Class>
  <owl:Class rdf:about="#विस्तारित_सार">
    <owl:disjointWith>
      <owl:Class rdf:about="#शोध_पत्र"/>
    </owl:disjointWith>
    <rdfs:subClassOf rdf:resource="#नियमित_योगदान"/>
  </owl:Class>
  <owl:Class rdf:about="#आमंत्रित_अध्यक्ष">
    <rdfs:subClassOf rdf:resource="#सम्मेलन_योगदानकर्ता"/>
    <owl:equivalentClass>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#आमंत्रित_बात"/>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#योगदान"/>
        </owl:onProperty>
      </owl:Restriction>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="सम्मेलन_www">
    <rdfs:subClassOf rdf:resource="#सम्मेलन_दस्तावेज़"/>
  </owl:Class>
  <owl:Class rdf:about="#शोध_पत्र">
    <rdfs:subClassOf rdf:resource="#नियमित_योगदान"/>
    <owl:disjointWith rdf:resource="#विस्तारित_सार"/>
  </owl:Class>
  <owl:Class rdf:about="#ट्यूटोरियल">
    <owl:disjointWith rdf:resource="#संकरा_रास्ता"/>
    <owl:disjointWith rdf:resource="#कार्यशाला"/>
    <rdfs:subClassOf rdf:resource="#सम्मेलन_भाग"/>
  </owl:Class>
  <owl:Class rdf:about="#पंजीकृत_आवेदक">
    <rdfs:subClassOf rdf:resource="#सम्मेलन_आवेदक"/>
  </owl:Class>
  <owl:Class rdf:about="#समीक्षित_योगदान">
    <rdfs:subClassOf rdf:resource="#सबमिट_किया_गया_योगदान"/>
    <owl:equivalentClass>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#स्वीकृत_योगदान"/>
          <owl:Class rdf:about="#अस्वीकृत_योगदान"/>
        </owl:unionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="सम्मेलन_शुल्क"/>
  <owl:Class rdf:about="#अर्ली_पेड_आवेदक">
    <owl:disjointWith rdf:resource="#देर_से_भुगतान_करने_वाला_आवेदक"/>
    <rdfs:subClassOf rdf:resource="#भुगतान_आवेदक"/>
  </owl:Class>
  <owl:Class rdf:ID="समीक्षा_वरीयता">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="विषय_या_सबमिशन_योगदान_है"/>
        </owl:onProperty>
        <owl:someValuesFrom>
          <owl:Class>
            <owl:unionOf rdf:parseType="Collection">
              <owl:Class rdf:about="#विषय"/>
              <owl:Class rdf:about="#सबमिट_किया_गया_योगदान"/>
            </owl:unionOf>
          </owl:Class>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#समीक्षकों_के_अंतर्गत_आता_है"/>
        </owl:onProperty>
        <owl:someValuesFrom rdf:resource="#समीक्षाक"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:ObjectProperty rdf:ID="की_एक_आयोजन_समिति_थी">
    <rdfs:range rdf:resource="#सम्मेलन_की_मात्रा"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:ID="एक_आयोजन_समिति_है"/>
    </owl:inverseOf>
    <rdfs:subPropertyOf>
      <owl:ObjectProperty rdf:ID="की_एक_समिति_थी"/>
