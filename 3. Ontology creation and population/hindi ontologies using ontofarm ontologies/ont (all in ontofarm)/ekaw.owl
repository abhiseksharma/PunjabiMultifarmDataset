      <owl:Class rdf:about="#सत्र"/>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="#डेमो_सत्र"/>
  </owl:Class>
  <owl:Class rdf:ID="ओसी_सदस्य">
    <rdfs:subClassOf rdf:resource="#सम्मेलन_प्रतिभागी"/>
  </owl:Class>
  <owl:Class rdf:about="#समीक्षा">
    <owl:disjointWith>
      <owl:Class rdf:about="#शोध_पत्र"/>
    </owl:disjointWith>
