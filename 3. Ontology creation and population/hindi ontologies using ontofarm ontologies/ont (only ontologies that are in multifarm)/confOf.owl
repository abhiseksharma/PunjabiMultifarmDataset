<?xml version="1.0"?>
<rdf:RDF    
	    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns="http://confOf#"
  xml:base="http://confOf">
  <owl:Ontology rdf:about=""/>  
  <owl:Class rdf:ID="यात्रा">    
    <owl:disjointWith>
      <owl:Class rdf:ID="भोज"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="स्वागत_समारोह"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:ID="सामाजिक_कार्यक्रम"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="कार्यक्रम">
    <owl:disjointWith>
      <owl:Class rdf:ID="योगदान"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="शहर"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="संगठन"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="व्यक्ति"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="विषय"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="देश"/>
    </owl:disjointWith>    
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:ID="संगठन">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#संगठन"/>
    </rdfs:subClassOf>    
    <owl:disjointWith>
      <owl:Class rdf:ID="विश्वविद्यालय"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="पंडित">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#व्यक्ति"/>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="में_अध्ययन"/>
        </owl:onProperty>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#विश्वविद्यालय"/>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >price category - scholar</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:allValuesFrom>
          <owl:Class rdf:about="#विश्वविद्यालय"/>
        </owl:allValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#में_अध्ययन"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="प्रशासक">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#व्यक्ति"/>
    </rdfs:subClassOf>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="#विषय">
    <owl:disjointWith>
      <owl:Class rdf:about="#देश"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#योगदान"/>
    </owl:disjointWith>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
    <owl:disjointWith>
      <owl:Class rdf:about="#संगठन"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#शहर"/>
    </owl:disjointWith>
    <owl:disjointWith rdf:resource="#कार्यक्रम"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#व्यक्ति"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:about="#योगदान">
    <owl:disjointWith>
      <owl:Class rdf:about="#देश"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:cardinality>
        <owl:onProperty>
          <owl:FunctionalProperty rdf:ID="है_शीर्षक"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:about="#शहर"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="के_साथ_सौदें"/>
        </owl:onProperty>
        <owl:someValuesFrom rdf:resource="#विषय"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">confTool</rdfs:comment>
    <owl:disjointWith rdf:resource="#कार्यक्रम"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#के_साथ_सौदें"/>
        </owl:onProperty>
        <owl:allValuesFrom rdf:resource="#विषय"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:minCardinality>
        <owl:onProperty>
          <owl:DatatypeProperty rdf:ID="ई_-_मेल_से_संपर्क_करे"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:about="#व्यक्ति"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:minCardinality>
        <owl:onProperty>
          <owl:DatatypeProperty rdf:ID="हैकीवर्ड"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:cardinality>
        <owl:onProperty>
          <owl:DatatypeProperty rdf:ID="सार"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>    
    <owl:disjointWith rdf:resource="#विषय"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#संगठन"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="पोस्टर">
    <owl:disjointWith>
      <owl:Class rdf:ID="शोध_पत्र"/>
    </owl:disjointWith>    
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
    <owl:disjointWith>
      <owl:Class rdf:ID="छोटा_शोध_पत्र"/>
    </owl:disjointWith>
    <rdfs:subClassOf rdf:resource="#योगदान"/>
  </owl:Class>
  <owl:Class rdf:about="#छोटा_शोध_पत्र">
    <owl:disjointWith rdf:resource="#पोस्टर"/>    
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
    <owl:disjointWith>
      <owl:Class rdf:about="#शोध_पत्र"/>
    </owl:disjointWith>
    <rdfs:subClassOf rdf:resource="#योगदान"/>
  </owl:Class>
  <owl:Class rdf:ID="समीक्षा_परिणाम_कार्यक्रम">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="प्रशासनिक_कार्यक्रम"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:ID="समीक्षा_कार्यक्रम"/>
    </owl:disjointWith>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Results of the reviewing procedures, accessable to authors</rdfs:comment>
    <owl:disjointWith>
      <owl:Class rdf:ID="प्रतिभागियों_की_कार्यक्रम_का_पंजीकरण"/>
    </owl:disjointWith>    
    <owl:disjointWith>
      <owl:Class rdf:ID="जमा_करने_का_कार्यक्रम"/>
    </owl:disjointWith>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
    <owl:disjointWith>
      <owl:Class rdf:ID="कैमरा_रेडी_कार्यक्रम"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="कार्यशाला">
    <owl:disjointWith>
      <owl:Class rdf:ID="सम्मेलन"/>
    </owl:disjointWith>    
    <owl:disjointWith>
      <owl:Class rdf:ID="ट्यूटोरियल"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:ID="कार्य_घटना"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#जमा_करने_का_कार्यक्रम">
    <owl:disjointWith>
      <owl:Class rdf:about="#प्रतिभागियों_की_कार्यक्रम_का_पंजीकरण"/>
    </owl:disjointWith>    
    <owl:disjointWith>
      <owl:Class rdf:about="#कैमरा_रेडी_कार्यक्रम"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#प्रशासनिक_कार्यक्रम"/>
    </rdfs:subClassOf>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Submission of contributions</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
    <owl:disjointWith>
      <owl:Class rdf:about="#समीक्षा_कार्यक्रम"/>
    </owl:disjointWith>
    <owl:disjointWith rdf:resource="#समीक्षा_परिणाम_कार्यक्रम"/>
  </owl:Class>
  <owl:Class rdf:about="#संगठन">
    <owl:disjointWith rdf:resource="#कार्यक्रम"/>    
    <owl:disjointWith>
      <owl:Class rdf:about="#व्यक्ति"/>
    </owl:disjointWith>
    <owl:disjointWith rdf:resource="#योगदान"/>
    <owl:disjointWith rdf:resource="#विषय"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#शहर"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#देश"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="सदस्य">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="प्रतिभागी"/>
    </rdfs:subClassOf>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="#कैमरा_रेडी_कार्यक्रम">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Final upload of accepted contributions</rdfs:comment>
    <owl:disjointWith>
      <owl:Class rdf:about="#समीक्षा_कार्यक्रम"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#प्रतिभागियों_की_कार्यक्रम_का_पंजीकरण"/>
    </owl:disjointWith>
    <owl:disjointWith rdf:resource="#समीक्षा_परिणाम_कार्यक्रम"/>
    <owl:disjointWith rdf:resource="#जमा_करने_का_कार्यक्रम"/>    
    <rdfs:subClassOf>
      <owl:Class rdf:about="#प्रशासनिक_कार्यक्रम"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#विश्वविद्यालय">    
    <rdfs:subClassOf rdf:resource="#संगठन"/>
    <owl:disjointWith rdf:resource="#संगठन"/>
  </owl:Class>
  <owl:Class rdf:about="#भोज">
    <owl:disjointWith rdf:resource="#यात्रा"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#स्वागत_समारोह"/>
    </owl:disjointWith>    
    <rdfs:subClassOf>
      <owl:Class rdf:about="#सामाजिक_कार्यक्रम"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#देश">
    <owl:disjointWith rdf:resource="#कार्यक्रम"/>
    <owl:disjointWith rdf:resource="#संगठन"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#व्यक्ति"/>
    </owl:disjointWith>
    <owl:disjointWith rdf:resource="#योगदान"/>
    <owl:disjointWith rdf:resource="#विषय"/>
  </owl:Class>
  <owl:Class rdf:about="#व्यक्ति">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:allValuesFrom rdf:resource="#संगठन"/>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="के_द्वारा_नियुक्त"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:DatatypeProperty rdf:ID="है_प्रथम_नाम"/>
        </owl:onProperty>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:FunctionalProperty rdf:ID="देश_है"/>
        </owl:onProperty>
        <owl:someValuesFrom rdf:resource="#देश"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:about="#शहर"/>
    </owl:disjointWith>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:minCardinality>
        <owl:onProperty>
          <owl:DatatypeProperty rdf:ID="ईमेल_है"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#के_द्वारा_नियुक्त"/>
        </owl:onProperty>
        <owl:someValuesFrom rdf:resource="#संगठन"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:DatatypeProperty rdf:ID="उपनाम_है"/>
        </owl:onProperty>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
    <owl:disjointWith rdf:resource="#विषय"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:minCardinality>
        <owl:onProperty>
          <owl:DatatypeProperty rdf:ID="है_स्ट्रीट"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="#संगठन"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:DatatypeProperty rdf:ID="है_डाक_कोड"/>
        </owl:onProperty>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="#देश"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="है_शहर"/>
        </owl:onProperty>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#शहर"/>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="#योगदान"/>
    <owl:disjointWith rdf:resource="#कार्यक्रम"/>
  </owl:Class>
  <owl:Class rdf:ID="कार्यक्रम_समिति_सदस्य">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="समीक्षा"/>
        </owl:onProperty>
        <owl:allValuesFrom rdf:resource="#योगदान"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:allValuesFrom rdf:resource="#विषय"/>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="पर_विशेषज्ञ"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Reviewer</rdfs:comment>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#योगदान"/>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#समीक्षा"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#विषय"/>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#पर_विशेषज्ञ"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#व्यक्ति"/>
  </owl:Class>
  <owl:Class rdf:about="#स्वागत_समारोह">
    <owl:disjointWith rdf:resource="#भोज"/>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#सामाजिक_कार्यक्रम"/>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="#यात्रा"/>    
  </owl:Class>
  <owl:Class rdf:ID="कार्यक्रम_समिति_अध्यक्ष">
    <rdfs:subClassOf rdf:resource="#व्यक्ति"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:ID="विद्यार्थी">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#प्रतिभागी"/>
    </rdfs:subClassOf>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:ID="विज्ञान_कार्यकर्ता">
    <rdfs:subClassOf rdf:resource="#व्यक्ति"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >confTool</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >price category - science worker</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="#सामाजिक_कार्यक्रम">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:FunctionalProperty rdf:ID="डिफ़ॉल्ट_विकल्प"/>
        </owl:onProperty>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:about="#कार्य_घटना"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:cardinality>
        <owl:onProperty>
          <owl:DatatypeProperty rdf:ID="स्थान"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:about="#प्रशासनिक_कार्यक्रम"/>
    </owl:disjointWith>
    <rdfs:subClassOf rdf:resource="#कार्यक्रम"/>    
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:cardinality>
        <owl:onProperty>
          <owl:FunctionalProperty rdf:ID="शीर्षक_है"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#प्रतिभागियों_की_कार्यक्रम_का_पंजीकरण">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#प्रशासनिक_कार्यक्रम"/>
    </rdfs:subClassOf>    
    <owl:disjointWith rdf:resource="#कैमरा_रेडी_कार्यक्रम"/>
    <owl:disjointWith rdf:resource="#समीक्षा_परिणाम_कार्यक्रम"/>
    <owl:disjointWith rdf:resource="#जमा_करने_का_कार्यक्रम"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
