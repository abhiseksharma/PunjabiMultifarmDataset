<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns="http://pcs#"
  xml:base="http://pcs">
  <owl:Ontology rdf:about=""/>
  <owl:Class rdf:ID="कार्यक्रम">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="सम्मेलन"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="बाहरी_समीक्षक">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="व्यक्ति"/>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:InverseFunctionalProperty rdf:ID="समीक्षा_लिखो"/>
        </owl:onProperty>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="समीक्षा"/>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:equivalentClass>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#समीक्षा"/>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="प्रस्तुत"/>
        </owl:onProperty>
      </owl:Restriction>
    </owl:equivalentClass>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:InverseFunctionalProperty rdf:ID="शोध_पत्र_पढ़ें"/>
        </owl:onProperty>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="स्वीकृत_शोध_पत्र"/>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:InverseFunctionalProperty rdf:ID="दर_शोध_पत्र"/>
        </owl:onProperty>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#स्वीकृत_शोध_पत्र"/>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="प्रतिवेदन"/>
  <owl:Class rdf:ID="माध्यमिक_समीक्षक">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="समिति_सदस्य"/>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:InverseFunctionalProperty rdf:about="#समीक्षा_लिखो"/>
        </owl:onProperty>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#समीक्षा"/>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#समीक्षा">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="दस्तावेज़"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="ईमेल"/>
  <owl:Class rdf:about="#समिति_सदस्य">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="सम्मेलन_सदस्य"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="जानकारी">
    <rdfs:subClassOf rdf:resource="#ईमेल"/>
  </owl:Class>
  <owl:Class rdf:ID="प्रशासक">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#व्यक्ति"/>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#प्रतिवेदन"/>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="उत्पन्न_करना"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#उत्पन्न_करना"/>
        </owl:onProperty>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="इलेक्ट्रॉनिक_कार्यवाही"/>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="भेजना"/>
        </owl:onProperty>
        <owl:someValuesFrom rdf:resource="#ईमेल"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="व्यवस्था"/>
  <owl:Class rdf:ID="सीडी">
    <rdfs:subClassOf rdf:resource="#इलेक्ट्रॉनिक_कार्यवाही"/>
