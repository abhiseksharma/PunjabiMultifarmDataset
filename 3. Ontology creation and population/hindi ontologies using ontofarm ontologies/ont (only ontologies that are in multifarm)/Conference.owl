    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="#महत्वपूर्ण_तिथियां_हैं"/>
  </owl:InverseFunctionalProperty>
  <owl:InverseFunctionalProperty rdf:about="#मुद्दे">
    <owl:inverseOf rdf:resource="#प्रकाशक_है"/>
    <rdfs:range rdf:resource="#सम्मेलन_की_कार्यवाही"/>
    <rdfs:domain rdf:resource="#प्रकाशक"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:InverseFunctionalProperty>
  <owl:InverseFunctionalProperty rdf:about="#एक_समीक्षा_संदर्भ_सौंपा_गया_है">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#सबमिट_किया_गया_योगदान"/>
          <owl:Class rdf:about="#विषय"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <owl:inverseOf rdf:resource="#विषय_या_सबमिशन_योगदान_है"/>
    <rdfs:range rdf:resource="#समीक्षा_वरीयता"/>
  </owl:InverseFunctionalProperty>
  <owl:InverseFunctionalProperty rdf:about="#की_एक_समिति_के_अध्यक्ष_थे">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="#का_सदस्य_था"/>
    <owl:inverseOf rdf:resource="#समिति_अध्यक्ष_है"/>
    <rdfs:range rdf:resource="#समिति"/>
    <rdfs:domain rdf:resource="#अध्यक्ष"/>
  </owl:InverseFunctionalProperty>
  <owl:InverseFunctionalProperty rdf:about="#समीक्षा_विशेषज्ञता_है">
    <rdfs:domain rdf:resource="#सबमिट_किया_गया_योगदान"/>
    <owl:inverseOf rdf:resource="#सबमिट_किया_गया_योगदान_है"/>
    <rdfs:range rdf:resource="#समीक्षा_विशेषज्ञ"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:InverseFunctionalProperty>
  <owl:InverseFunctionalProperty rdf:about="#का_1वाँ_भाग_है">
    <owl:inverseOf rdf:resource="#एक_सार_है"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="#सार"/>
    <rdfs:range>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#शोध_पत्र"/>
          <owl:Class rdf:about="#पोस्टर"/>
