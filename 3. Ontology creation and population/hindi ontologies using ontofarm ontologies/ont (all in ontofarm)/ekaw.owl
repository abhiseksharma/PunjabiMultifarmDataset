    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#अस्वीकृत_कागज">
    <owl:disjointWith rdf:resource="#स्वीकृत_शोध_पत्र"/>
    <rdfs:subClassOf rdf:resource="#मूल्यांकन_शोध_पत्र"/>
  </owl:Class>
  <owl:Class rdf:about="#सम्मेलन_शोध_पत्र">
    <owl:disjointWith rdf:resource="#वर्कशॉप_पेपर"/>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#शोध_पत्र"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#औद्योगिक_शोध_पत्र">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#शोध_पत्र"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:ID="पोस्टर_पत्र"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="नियमित_शोध_पत्र"/>
