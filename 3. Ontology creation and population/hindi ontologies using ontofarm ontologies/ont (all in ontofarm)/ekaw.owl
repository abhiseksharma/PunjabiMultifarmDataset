<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:daml="http://www.daml.org/2001/03/daml+oil#"
    xmlns="http://ekaw#"
    xmlns:dc="http://purl.org/dc/elements/1.1/"
  xml:base="http://ekaw">
  <owl:Ontology rdf:about=""/>  
  <owl:Class rdf:ID="कार्यक्रम">
    <owl:disjointWith>
      <owl:Class rdf:ID="व्यक्ति"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="स्वीकृत_शोध_पत्र">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Accepted paper to become part of proceedings. 
Note that camera-ready paper is not considered as 'accepted paper', as it was accepted in a different form!</rdfs:comment>
    <owl:disjointWith>
      <owl:Class rdf:ID="अस्वीकृत_कागज"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:ID="मूल्यांकन_शोध_पत्र"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:ID="कैमरा_तैयार_शोध_पत्र"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="सकारात्मक_समीक्षा"/>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="है_समीक्षा"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="वर्कशॉप_पेपर">
    <owl:disjointWith>
      <owl:Class rdf:ID="औद्योगिक_शोध_पत्र"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:ID="शोध_पत्र"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:ID="सम्मेलन_शोध_पत्र"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="औद्योगिक_सत्र">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="सम्मेलन_सत्र"/>
    </rdfs:subClassOf>    
  </owl:Class>
  <owl:Class rdf:ID="नियमित_सत्र">
    <owl:disjointWith>
      <owl:Class rdf:ID="पोस्टर_सत्र"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="डेमो_सत्र"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:ID="सत्र"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="सार">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="दस्तावेज़"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="शोध_पत्र_लेखक">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#व्यक्ति"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="सम्मेलन_यात्रा">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="सामाजिक_कार्यक्रम"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="ट्यूटोरियल_सार">
    <rdfs:subClassOf rdf:resource="#सार"/>
  </owl:Class>
  <owl:Class rdf:about="#कैमरा_तैयार_शोध_पत्र">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="द्वारा_लिखित"/>
        </owl:onProperty>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="सम्मेलन_प्रतिभागी"/>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:ID="सबमिट_किया_गया_पेपर"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#शोध_पत्र"/>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="#स्वीकृत_शोध_पत्र"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#मूल्यांकन_शोध_पत्र"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="का_अद्यतन_संस्करण"/>
        </owl:onProperty>
        <owl:someValuesFrom rdf:resource="#स्वीकृत_शोध_पत्र"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#मूल्यांकन_शोध_पत्र">
    <owl:disjointWith rdf:resource="#कैमरा_तैयार_शोध_पत्र"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#है_समीक्षा"/>
        </owl:onProperty>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >3</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Class rdf:ID="असाइन_किया_गया_पेपर"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#सकारात्मक_समीक्षा">
    <owl:disjointWith>
      <owl:Class rdf:ID="नकारात्मक_समीक्षा"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:ID="समीक्षा"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:ID="निष्पक्ष_समीक्षा"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="शोध_विषय"/>
  <owl:Class rdf:ID="आयोजन_एजेंसी">
