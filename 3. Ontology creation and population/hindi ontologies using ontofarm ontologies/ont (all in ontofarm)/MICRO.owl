    <owl:inverseOf rdf:resource="#आयोजन"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#है_लेखक">
    <owl:inverseOf rdf:resource="#के_लेखक_हैं"/>
    <rdfs:range rdf:resource="#लेखक"/>
