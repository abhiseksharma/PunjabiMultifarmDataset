    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#द्वारा_संचालित_है">
    <owl:inverseOf rdf:resource="#आयोजित"/>
    <rdfs:range rdf:resource="#लेखक"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#ट्यूटोरियल"/>
