    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:about="#नकारात्मक_समीक्षा"/>
    </owl:disjointWith>
    <owl:disjointWith rdf:resource="#सकारात्मक_समीक्षा"/>
  </owl:Class>
  <owl:Class rdf:ID="एजेंसी_स्टाफ_सदस्य">
    <rdfs:subClassOf rdf:resource="#व्यक्ति"/>
  </owl:Class>
  <owl:Class rdf:about="#संगठन">
    <owl:disjointWith rdf:resource="#व्यक्ति"/>
  </owl:Class>
  <owl:Class rdf:ID="कार्यशाला_सत्र">
