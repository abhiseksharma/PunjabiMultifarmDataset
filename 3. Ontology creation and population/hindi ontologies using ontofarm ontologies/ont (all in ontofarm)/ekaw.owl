    <owl:disjointWith>
      <owl:Class rdf:ID="डेमो_शोध_पत्र"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:about="#व्यक्ति">
    <owl:disjointWith>
      <owl:Class rdf:ID="स्थान"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#दस्तावेज़"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#संगठन"/>
    </owl:disjointWith>
    <owl:disjointWith rdf:resource="#कार्यक्रम"/>
  </owl:Class>
  <owl:Class rdf:ID="अनुसंधान_संस्थान">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#शैक्षणिक_संस्थान"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="वैज्ञानिक_कार्यक्रम">
    <rdfs:subClassOf rdf:resource="#कार्यक्रम"/>
  </owl:Class>
  <owl:Class rdf:about="#शैक्षणिक_संस्थान">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#संगठन"/>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="#आयोजन_एजेंसी"/>
  </owl:Class>
  <owl:Class rdf:about="#डेमो_सत्र">
    <owl:disjointWith>
      <owl:Class rdf:about="#पोस्टर_सत्र"/>
    </owl:disjointWith>    
    <owl:disjointWith rdf:resource="#नियमित_सत्र"/>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#सत्र"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#असाइन_किया_गया_पेपर">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#सबमिट_किया_गया_पेपर"/>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="है_समीक्षक"/>
        </owl:onProperty>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >3</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="आमंत्रित_टॉक_सार">
    <rdfs:subClassOf rdf:resource="#सार"/>
  </owl:Class>
  <owl:Class rdf:about="#निष्पक्ष_समीक्षा">
    <rdfs:subClassOf>
