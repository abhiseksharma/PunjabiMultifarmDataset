<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns="http://crs_dr#"
  xml:base="http://crs_dr">
  <owl:Ontology rdf:about=""/>
  <owl:Class rdf:ID="लेखक">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="व्यक्ति"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="कार्यक्रम_समिति_की_बैठक">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="कार्यक्रम"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:ID="सत्र"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="सम्मेलन"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="अध्यक्ष">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#व्यक्ति"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="सार">
    <owl:disjointWith>
      <owl:Class rdf:ID="लेख"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:ID="दस्तावेज़"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:ID="समीक्षा"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:about="#लेख">
    <owl:disjointWith rdf:resource="#सार"/>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#दस्तावेज़"/>
    </rdfs:subClassOf>
    <owl:disjointWith>
      <owl:Class rdf:about="#समीक्षा"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:ID="प्रतिभागी">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#व्यक्ति"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#दस्तावेज़">
    <owl:disjointWith>
      <owl:Class rdf:about="#कार्यक्रम"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:about="#व्यक्ति"/>
    </owl:disjointWith>
    <owl:disjointWith>
      <owl:Class rdf:ID="कार्यक्रम"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:about="#सम्मेलन">
    <owl:disjointWith rdf:resource="#कार्यक्रम_समिति_की_बैठक"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#सत्र"/>
    </owl:disjointWith>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#कार्यक्रम"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#कार्यक्रम">
    <owl:disjointWith>
      <owl:Class rdf:about="#व्यक्ति"/>
    </owl:disjointWith>
    <owl:disjointWith rdf:resource="#दस्तावेज़"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#कार्यक्रम"/>
    </owl:disjointWith>
  </owl:Class>
  <owl:Class rdf:about="#समीक्षा">
    <owl:disjointWith rdf:resource="#लेख"/>
    <rdfs:subClassOf rdf:resource="#दस्तावेज़"/>
    <owl:disjointWith rdf:resource="#सार"/>
  </owl:Class>
  <owl:Class rdf:about="#सत्र">
    <owl:disjointWith rdf:resource="#कार्यक्रम_समिति_की_बैठक"/>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#कार्यक्रम"/>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="#सम्मेलन"/>
  </owl:Class>
  <owl:Class rdf:about="#व्यक्ति">
    <owl:disjointWith rdf:resource="#कार्यक्रम"/>
    <owl:disjointWith>
      <owl:Class rdf:about="#कार्यक्रम"/>
    </owl:disjointWith>
    <owl:disjointWith rdf:resource="#दस्तावेज़"/>
  </owl:Class>
  <owl:Class rdf:about="#कार्यक्रम">
    <owl:disjointWith rdf:resource="#व्यक्ति"/>
    <owl:disjointWith rdf:resource="#कार्यक्रम"/>
    <owl:disjointWith rdf:resource="#दस्तावेज़"/>
  </owl:Class>
  <owl:Class rdf:ID="समीक्षाक">
    <rdfs:subClassOf rdf:resource="#व्यक्ति"/>
  </owl:Class>
  <owl:ObjectProperty rdf:ID="द्वारा_बनाया_गया_कार्यक्रम">
    <owl:inverseOf>
      <owl:ObjectProperty rdf:ID="कार्यक्रम_बनाता_है"/>
    </owl:inverseOf>
    <rdfs:range rdf:resource="#अध्यक्ष"/>
    <rdfs:domain rdf:resource="#कार्यक्रम"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="राइट्स_रिव्यू">
    <owl:inverseOf>
      <owl:ObjectProperty rdf:ID="द्वारा_लिखी_गई_समीक्षाएं"/>
    </owl:inverseOf>
    <rdfs:range rdf:resource="#समीक्षा"/>
    <rdfs:domain rdf:resource="#समीक्षाक"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="राइट्स_आर्टिकल">
    <rdfs:range rdf:resource="#लेख"/>
    <rdfs:domain rdf:resource="#लेखक"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:ID="लेख_लिखित_द्वारा"/>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="लेखक_है">
    <rdfs:domain rdf:resource="#लेख"/>
    <rdfs:range rdf:resource="#लेखक"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#लेख_लिखित_द्वारा">
    <rdfs:range rdf:resource="#लेखक"/>
    <rdfs:domain rdf:resource="#लेख"/>
    <owl:inverseOf rdf:resource="#राइट्स_आर्टिकल"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="समीक्षक_है">
    <rdfs:domain rdf:resource="#लेख"/>
    <rdfs:range rdf:resource="#समीक्षाक"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="सबमिट_टू_कॉन्फ्रेंस">
    <rdfs:range rdf:resource="#सम्मेलन"/>
    <rdfs:domain rdf:resource="#प्रतिभागी"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="असाइनमेंट_आर्टिकल_टू_कॉन्फ्रेंस">
    <rdfs:range rdf:resource="#लेख"/>
    <rdfs:domain rdf:resource="#लेखक"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="असाइनमेंट_समीक्षक_टू_आर्टिकल">
    <rdfs:range rdf:resource="#समीक्षाक"/>
    <rdfs:domain rdf:resource="#अध्यक्ष"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="लेख_का_हिस्सा">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:range rdf:resource="#लेख"/>
    <rdfs:domain rdf:resource="#सार"/>
    <owl:inverseOf>
      <owl:FunctionalProperty rdf:ID="है_सार"/>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#द्वारा_लिखी_गई_समीक्षाएं">
    <rdfs:domain rdf:resource="#समीक्षा"/>
    <owl:inverseOf rdf:resource="#राइट्स_रिव्यू"/>
    <rdfs:range rdf:resource="#समीक्षाक"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#कार्यक्रम_बनाता_है">
    <rdfs:range rdf:resource="#कार्यक्रम"/>
    <rdfs:domain rdf:resource="#अध्यक्ष"/>
    <owl:inverseOf rdf:resource="#द्वारा_बनाया_गया_कार्यक्रम"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="प्रोग्राम_है">
    <rdfs:range rdf:resource="#कार्यक्रम"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="#सम्मेलन"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="सेशन_है_">
    <rdfs:domain rdf:resource="#कार्यक्रम"/>
    <rdfs:range rdf:resource="#सत्र"/>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:ID="शुरू_होने_की_तारीख_है">
    <rdfs:domain rdf:resource="#कार्यक्रम"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  </owl:DatatypeProperty>
  <owl:FunctionalProperty rdf:ID="समाप्ति_तिथि_है">
    <rdfs:domain rdf:resource="#कार्यक्रम"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="#है_सार">
    <owl:inverseOf rdf:resource="#लेख_का_हिस्सा"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="#सार"/>
    <rdfs:domain rdf:resource="#लेख"/>
  </owl:FunctionalProperty>
</rdf:RDF>

