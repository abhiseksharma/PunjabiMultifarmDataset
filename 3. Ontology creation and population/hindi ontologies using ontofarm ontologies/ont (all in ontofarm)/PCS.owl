        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="प्राप्त"/>
        </owl:onProperty>
      </owl:Restriction>
    </owl:equivalentClass>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#व्यक्ति"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="वेबसाइट">
    <rdfs:subClassOf rdf:resource="#इलेक्ट्रॉनिक_कार्यवाही"/>
  </owl:Class>
  <owl:Class rdf:ID="अस्वीकृत_कागज">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#शोध_पत्र"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#व्यक्ति">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#प्राप्त"/>
        </owl:onProperty>
        <owl:someValuesFrom rdf:resource="#जानकारी"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:equivalentClass>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#व्यवस्था"/>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="प्रवेश_किया"/>
        </owl:onProperty>
      </owl:Restriction>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="लेखक">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#शोध_पत्र"/>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:InverseFunctionalProperty rdf:ID="राइट_पेपर"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:equivalentClass>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#शोध_पत्र"/>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#प्रस्तुत"/>
        </owl:onProperty>
      </owl:Restriction>
    </owl:equivalentClass>
    <rdfs:subClassOf rdf:resource="#सम्मेलन_सदस्य"/>
  </owl:Class>
  <owl:Class rdf:about="#शोध_पत्र">
    <rdfs:subClassOf rdf:resource="#दस्तावेज़"/>
  </owl:Class>
  <owl:Class rdf:about="#आमंत्रण">
    <rdfs:subClassOf rdf:resource="#ईमेल"/>
  </owl:Class>
  <owl:Class rdf:ID="प्राथमिक_समीक्षक">
    <rdfs:subClassOf rdf:resource="#समिति_सदस्य"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="असाइन_रिव्यू"/>
        </owl:onProperty>
        <owl:someValuesFrom rdf:resource="#समीक्षा"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:InverseFunctionalProperty rdf:ID="स्वीकार_करना"/>
        </owl:onProperty>
        <owl:someValuesFrom rdf:resource="#शोध_पत्र"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:ObjectProperty rdf:about="#भेजना">
    <rdfs:range rdf:resource="#ईमेल"/>
    <rdfs:domain rdf:resource="#प्रशासक"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:ID="द्वारा_भेजा_गया"/>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="द्वारा_शोध_पत्र_पढ़ें">
    <rdfs:domain rdf:resource="#स्वीकृत_शोध_पत्र"/>
    <rdfs:range>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#बाहरी_समीक्षक"/>
          <owl:Class rdf:about="#माध्यमिक_समीक्षक"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:range>
    <owl:inverseOf>
      <owl:InverseFunctionalProperty rdf:about="#शोध_पत्र_पढ़ें"/>
    </owl:inverseOf>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="नियत_समीक्षा_द्वारा">
    <rdfs:domain rdf:resource="#समीक्षा"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="#असाइन_रिव्यू"/>
    </owl:inverseOf>
    <rdfs:range rdf:resource="#प्राथमिक_समीक्षक"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="सम्मेलन_सदस्य_है">
    <rdfs:domain rdf:resource="#सम्मेलन"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:ID="सम्मेलन_के_सदस्य"/>
    </owl:inverseOf>
    <rdfs:range rdf:resource="#सम्मेलन_सदस्य"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="प्रस्तुत_द्वारा">
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="#प्रस्तुत"/>
    </owl:inverseOf>
    <rdfs:domain rdf:resource="#दस्तावेज़"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:range rdf:resource="#व्यक्ति"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#द्वारा_भेजा_गया">
    <rdfs:range rdf:resource="#प्रशासक"/>
    <rdfs:domain rdf:resource="#ईमेल"/>
    <owl:inverseOf rdf:resource="#भेजना"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#असाइन_रिव्यू">
    <owl:inverseOf rdf:resource="#नियत_समीक्षा_द्वारा"/>
    <rdfs:domain rdf:resource="#प्राथमिक_समीक्षक"/>
    <rdfs:range rdf:resource="#समीक्षा"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#प्रवेश_किया">
    <rdfs:domain rdf:resource="#व्यक्ति"/>
    <rdfs:range rdf:resource="#व्यवस्था"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#प्रस्तुत">
    <rdfs:range rdf:resource="#दस्तावेज़"/>
    <owl:inverseOf rdf:resource="#प्रस्तुत_द्वारा"/>
    <rdfs:domain rdf:resource="#व्यक्ति"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#उत्पन्न_करना">
    <rdfs:range>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#प्रतिवेदन"/>
          <owl:Class rdf:about="#इलेक्ट्रॉनिक_कार्यवाही"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:range>
    <rdfs:domain rdf:resource="#प्रशासक"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:ID="द्वारा_उत्पन्न"/>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="द्वारा_मूल्यांकित_शोध_पत्र">
    <owl:inverseOf>
      <owl:InverseFunctionalProperty rdf:about="#दर_शोध_पत्र"/>
    </owl:inverseOf>
    <rdfs:domain rdf:resource="#स्वीकृत_शोध_पत्र"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#बाहरी_समीक्षक"/>
          <owl:Class rdf:about="#माध्यमिक_समीक्षक"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:range>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#प्राप्त">
    <rdfs:range rdf:resource="#ईमेल"/>
    <rdfs:domain rdf:resource="#व्यक्ति"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#द्वारा_उत्पन्न">
    <owl:inverseOf rdf:resource="#उत्पन्न_करना"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#प्रतिवेदन"/>
          <owl:Class rdf:about="#इलेक्ट्रॉनिक_कार्यवाही"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="#प्रशासक"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#सम्मेलन_के_सदस्य">
    <rdfs:domain rdf:resource="#सम्मेलन_सदस्य"/>
    <owl:inverseOf rdf:resource="#सम्मेलन_सदस्य_है"/>
    <rdfs:range rdf:resource="#सम्मेलन"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="अस्वीकार_कागज">
    <rdfs:domain rdf:resource="#समिति_सदस्य"/>
    <rdfs:range rdf:resource="#शोध_पत्र"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <owl:inverseOf>
      <owl:FunctionalProperty rdf:ID="अस्वीकृत_कागज_द्वारा"/>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:ID="वेबसाइट">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <rdfs:domain rdf:resource="#सम्मेलन"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="शीर्षक">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="#शोध_पत्र"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="यूज़र_आईडी">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#व्यक्ति"/>
          <owl:Class rdf:about="#व्यवस्था"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="विषय_का_सम्मेलन">
    <rdfs:domain rdf:resource="#सम्मेलन"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="रिसीवर_ऑफ_ईमेल">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="#ईमेल"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="ईमेल_का_संदेश">
    <rdfs:domain rdf:resource="#ईमेल"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="विषय_ऑफ_ईमेल">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="#ईमेल"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="ईमेल">
    <rdfs:domain rdf:resource="#व्यक्ति"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="पासवर्ड">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#व्यक्ति"/>
          <owl:Class rdf:about="#व्यवस्था"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="नाम">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#सम्मेलन"/>
          <owl:Class rdf:about="#व्यक्ति"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="अंक">
    <rdfs:domain rdf:resource="#स्वीकृत_शोध_पत्र"/>
    <rdfs:range>
      <owl:DataRange>
        <owl:oneOf rdf:parseType="Resource">
          <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
          >1</rdf:first>
          <rdf:rest rdf:parseType="Resource">
            <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
            >2</rdf:first>
            <rdf:rest rdf:parseType="Resource">
              <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
              >3</rdf:first>
              <rdf:rest rdf:parseType="Resource">
                <rdf:rest rdf:parseType="Resource">
                  <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
                  >5</rdf:first>
                  <rdf:rest rdf:parseType="Resource">
                    <rdf:rest rdf:parseType="Resource">
                      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                      <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
                      >7</rdf:first>
                    </rdf:rest>
                    <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
                    >6</rdf:first>
                  </rdf:rest>
                </rdf:rest>
                <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
                >4</rdf:first>
              </rdf:rest>
            </rdf:rest>
          </rdf:rest>
        </owl:oneOf>
      </owl:DataRange>
    </rdfs:range>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="दस्तावेज़_आईडी">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    <rdfs:domain rdf:resource="#दस्तावेज़"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="सारांश">
    <rdfs:domain rdf:resource="#शोध_पत्र"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:FunctionalProperty rdf:about="#अस्वीकृत_कागज_द्वारा">
    <rdfs:domain rdf:resource="#शोध_पत्र"/>
    <rdfs:range rdf:resource="#समिति_सदस्य"/>
    <owl:inverseOf rdf:resource="#अस्वीकार_कागज"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:ID="इसके_द्वारा_स्वीकृत">
    <owl:inverseOf>
      <owl:InverseFunctionalProperty rdf:about="#स्वीकार_करना"/>
    </owl:inverseOf>
    <rdfs:domain rdf:resource="#शोध_पत्र"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="#समिति_सदस्य"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:ID="लिखित_कागज_द्वारा">
    <owl:inverseOf>
      <owl:InverseFunctionalProperty rdf:about="#राइट_पेपर"/>
    </owl:inverseOf>
    <rdfs:domain rdf:resource="#शोध_पत्र"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:range rdf:resource="#लेखक"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:ID="लिखित_समीक्षा_द्वारा">
    <rdfs:domain rdf:resource="#समीक्षा"/>
    <rdfs:range>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#माध्यमिक_समीक्षक"/>
          <owl:Class rdf:about="#बाहरी_समीक्षक"/>
